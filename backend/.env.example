# Backend Environment Variables

# Database Connection
MONGODB_URI=mongodb://localhost:27017/grievance-portal

# Server Configuration
PORT=4000

# Email Service (Gmail with App Password)
# 1. Enable 2FA on your Gmail account
# 2. Get an App Password: https://myaccount.google.com/apppasswords
# 3. Copy the 16-character password below (without spaces)
EMAIL_USER=your-email@gmail.com
EMAIL_PASSWORD=your-16-char-app-password

# CORS Settings (comma-separated domains allowed to call this API)
# For local dev: http://localhost:3000,http://localhost:3001
# For production: https://your-frontend-domain.com
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001
